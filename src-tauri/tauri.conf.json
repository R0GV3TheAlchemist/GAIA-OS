{
  "productName": "GAIA",
  "version": "0.1.0",
  "identifier": "earth.gaia.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GAIA",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "shadow": true,
        "visible": false
      }
    ],
    "trayIcon": {
      "id": "gaia-tray",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "title": "GAIA",
      "tooltip": "GAIA — Your Sovereign AI"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8008 https://*.run.app; style-src 'self' 'unsafe-inline' https://api.fontshare.com https://fonts.googleapis.com; font-src 'self' https://api.fontshare.com https://fonts.gstatic.com; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/gaia-backend"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "language": "en-US",
        "upgradeCode": "4A7F1B2C-8E3D-4F56-A9B0-C1D2E3F40506",
        "appicon": "icons/icon.ico",
        "dialogImagePath": "icons/installer/wix-dialog.bmp",
        "bannerBmpPath": "icons/installer/wix-banner.bmp"
      },
      "nsis": {
        "languages": ["English"],
        "installMode": "perMachine",
        "compression": "lzma",
        "headerImage": "icons/installer/nsis-header.bmp",
        "sidebarImage": "icons/installer/nsis-sidebar.bmp"
      }
    },
    "publisher": "R0GV3 the Alchemist",
    "copyright": "Copyright © 2026 R0GV3 the Alchemist",
    "category": "Productivity",
    "shortDescription": "GAIA — Sovereign AI Companion",
    "longDescription": "GAIA is a sovereign cross-platform AI companion built on alchemical principles, quantum cognition, and deep human-AI partnership.",
    "supportUrl": "https://github.com/R0GV3TheAlchemist/GAIA-OS/issues"
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzQzIwOTRGOUUzMTM5NApSV1NVRStQNWxDQThBbEttM250OEErT3QzYnRqVS90NXJ6QUc2NVErSEc2bU9KQjFQSFR2MWtPago=",
      "endpoints": [
        "https://github.com/R0GV3TheAlchemist/GAIA-APP/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
