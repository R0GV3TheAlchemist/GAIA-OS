# GAIA Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file.

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
GAIA_MODEL=llama3

# ── Server ───────────────────────────────────────────────────────────────────
GAIA_PORT=8008

# ── IBM Quantum (P6 Part 2 — optional) ───────────────────────────────────
# Required only for quantum circuit execution on real IBM hardware.
# If not set, GAIA uses the local Qiskit Aer simulator automatically.
IBMQ_API_KEY=

# ── Post-Quantum Encryption (P6 Part 1) ────────────────────────────────
# Set to 1 to enable ML-KEM/ML-DSA encryption (requires liboqs-python).
# If liboqs is not installed, GAIA falls back to AES-256-GCM automatically.
GAIA_PQC_ENABLED=1
