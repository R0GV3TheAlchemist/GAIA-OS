# GAIA Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file.

# ── Ollama (local LLM — offline / privacy-first mode) ────────────────────────
# Ollama base URL — default assumes local install
OLLAMA_BASE_URL=http://localhost:11434

# The model GAIA uses when routing to Ollama.
# Recommended default: gemma3:12b  (128K ctx, best quality/speed balance on mid-range hardware)
# Fallback (low-RAM):   llama3.1:8b
# High-fidelity:        qwen2.5:32b  (requires 24 GB+ VRAM)
# Ultra-light (CPU):    phi4-mini
OLLAMA_MODEL=gemma3:12b

# Legacy alias — kept for backwards compatibility; OLLAMA_MODEL takes precedence
GAIA_MODEL=gemma3:12b

# Set to 1 to explicitly enable Ollama even when cloud keys are present
OLLAMA_ENABLED=0

# ── Cloud LLM backends (all optional — GAIA works fully offline without them) ─
# Perplexity — used for web-grounded queries (sonar / sonar-pro / sonar-reasoning-pro)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# OpenAI — fallback after Perplexity
OPENAI_API_KEY=

# Anthropic — fallback after OpenAI
ANTHROPIC_API_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Server ───────────────────────────────────────────────────────────────────
GAIA_PORT=8008

# ── IBM Quantum (P6 Part 2 — optional) ───────────────────────────────────────
# Required only for quantum circuit execution on real IBM hardware.
# If not set, GAIA uses the local Qiskit Aer simulator automatically.
IBMQ_API_KEY=

# ── Post-Quantum Encryption (P6 Part 1) ──────────────────────────────────────
# Set to 1 to enable ML-KEM/ML-DSA encryption (requires liboqs-python).
# If liboqs is not installed, GAIA falls back to AES-256-GCM automatically.
GAIA_PQC_ENABLED=1
