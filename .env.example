# ============================================================
#  GAIA-APP — Environment Configuration
#  Copy this file to .env and fill in what you have.
#  NOTHING below is required. GAIA runs 100% free with Ollama.
# ============================================================

# ── FREE LOCAL AI (Recommended — No key needed) ─────────────
# 1. Install Ollama: https://ollama.com  (free, runs on your machine)
# 2. Run: ollama pull gemma3:1b          (small, fast, works on old laptops)
# 3. Set the model name below and you're done.
OLLAMA_MODEL=gemma3:1b
# Other good free models (pick one):
# OLLAMA_MODEL=llama3.2:1b       (Meta — very capable)
# OLLAMA_MODEL=mistral            (great for reasoning)
# OLLAMA_MODEL=phi3:mini          (Microsoft — tiny and smart)

# ── OPTIONAL PAID KEYS (only add if you have them) ──────────
# You do NOT need these. GAIA works fine without them.

# OpenAI (https://platform.openai.com)
# OPENAI_API_KEY=sk-...

# Anthropic Claude (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...

# Perplexity Search (https://www.perplexity.ai/settings/api)
# PERPLEXITY_API_KEY=pplx-...
# PERPLEXITY_MODEL=sonar-pro

# ── APP SETTINGS (safe defaults — no need to change) ────────
GAIA_PORT=8008
GAIA_HOST=127.0.0.1
LOG_LEVEL=INFO
